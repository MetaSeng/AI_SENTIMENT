// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum SentimentLabel {
  positive
  neutral
  negative
}

enum RunMode {
  DEMO
  LIVE
}

enum RunStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELED
}

enum SourcePlatform {
  FACEBOOK
}

enum SourceStatus {
  PENDING
  TRIGGERED
  READY
  FAILED
}

enum InsightType {
  success
  warning
  danger
  info
}

enum RecommendationKind {
  TOP_PERFORMER
  NEEDS_IMPROVEMENT
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  passwordHash  String?
  fullName      String?
  businessName  String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  projects      Project[]
  settings      UserSetting?
  analysisRuns  AnalysisRun[]
}

model UserSetting {
  id                  String   @id @default(cuid())
  userId              String   @unique
  emailNotifications  Boolean  @default(true)
  sentimentAlerts     Boolean  @default(true)
  weeklyDigest        Boolean  @default(false)
  theme               String?
  defaultDateRange    String?
  apiBaseUrl          String?
  apiKeyEncrypted     String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Project {
  id            String         @id @default(cuid())
  ownerId       String
  name          String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  owner         User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  products      Product[]
  runs          AnalysisRun[]
  integrations  Integration[]
}

model Integration {
  id              String          @id @default(cuid())
  projectId       String
  platform        SourcePlatform
  displayName     String?
  externalPageId  String?
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  project         Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, platform])
}

model Product {
  id              String            @id @default(cuid())
  projectId       String
  name            String
  category        String?           @default("General")
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  project         Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceLinks     AnalysisSource[]
  cleanedComments CleanComment[]
  runMetrics      ProductRunMetric[]
  keywordMetrics  KeywordMetric[]
  recommendations RecommendationItem[]

  @@unique([projectId, name])
  @@index([projectId])
}

model AnalysisRun {
  id                String               @id @default(cuid())
  projectId         String
  initiatedByUserId String?
  mode              RunMode
  status            RunStatus            @default(QUEUED)
  startedAt         DateTime?
  finishedAt        DateTime?
  errorMessage      String?
  totalComments     Int                  @default(0)
  productCount      Int                  @default(0)
  avgSentimentScore Decimal?             @db.Decimal(5, 4)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  project           Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  initiatedBy       User?                @relation(fields: [initiatedByUserId], references: [id], onDelete: SetNull)
  events            RunEvent[]
  sources           AnalysisSource[]
  rawComments       RawComment[]
  cleanedComments   CleanComment[]
  productMetrics    ProductRunMetric[]
  keywordMetrics    KeywordMetric[]
  insights          Insight[]
  recommendations   RecommendationItem[]

  @@index([projectId, createdAt])
  @@index([status, createdAt])
}

model RunEvent {
  id              String      @id @default(cuid())
  runId           String
  stage           String
  progressPercent Int?
  message         String?
  createdAt       DateTime    @default(now())

  run             AnalysisRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, createdAt])
}

model AnalysisSource {
  id               String         @id @default(cuid())
  runId            String
  productId        String?
  inputProductName String
  inputUrl         String
  resolvedUrl      String?
  snapshotId       String?
  status           SourceStatus   @default(PENDING)
  sourceError      String?
  triggeredAt      DateTime?
  readyAt          DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  run              AnalysisRun    @relation(fields: [runId], references: [id], onDelete: Cascade)
  product          Product?       @relation(fields: [productId], references: [id], onDelete: SetNull)
  rawComments      RawComment[]
  cleanedComments  CleanComment[]

  @@index([runId])
  @@index([snapshotId])
}

model RawComment {
  id                String         @id @default(cuid())
  runId             String
  sourceId          String
  externalPostId    String?
  externalCommentId String?
  externalAuthorId  String?
  rawText           String?        @db.Text
  rawDate           DateTime?
  rawAuthorName     String?
  rawLikes          Int?
  rawPayload        Json
  ingestedAt        DateTime       @default(now())

  run               AnalysisRun    @relation(fields: [runId], references: [id], onDelete: Cascade)
  source            AnalysisSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  cleaned           CleanComment?

  @@index([runId, sourceId])
  @@index([externalCommentId])
}

model CleanComment {
  id               String          @id @default(cuid())
  runId            String
  sourceId         String
  rawCommentId     String          @unique
  productId        String?
  cleanedText      String          @db.Text
  normalizedDate   DateTime?
  normalizedAuthor String?
  normalizedLikes  Int             @default(0)
  languageCode     String?
  isSpam           Boolean         @default(false)
  isDuplicate      Boolean         @default(false)
  cleaningMeta     Json?
  sentiment        SentimentLabel
  sentimentScore   Decimal         @db.Decimal(5, 4)
  createdAt        DateTime        @default(now())

  run              AnalysisRun     @relation(fields: [runId], references: [id], onDelete: Cascade)
  source           AnalysisSource  @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  rawComment       RawComment      @relation(fields: [rawCommentId], references: [id], onDelete: Cascade)
  product          Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([runId, sentiment])
  @@index([runId, productId])
  @@index([normalizedDate])
}

model ProductRunMetric {
  id                String      @id @default(cuid())
  runId             String
  productId         String
  mentionCount      Int
  positivePercent   Int
  neutralPercent    Int
  negativePercent   Int
  avgSentimentScore Decimal     @db.Decimal(5, 4)
  createdAt         DateTime    @default(now())

  run               AnalysisRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  product           Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([runId, productId])
  @@index([runId])
}

model KeywordMetric {
  id         String         @id @default(cuid())
  runId      String
  productId  String?
  word       String
  sentiment  SentimentLabel
  count      Int
  createdAt  DateTime       @default(now())

  run        AnalysisRun    @relation(fields: [runId], references: [id], onDelete: Cascade)
  product    Product?       @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([runId, count])
  @@index([runId, productId])
}

model Insight {
  id          String       @id @default(cuid())
  runId       String
  icon        String
  title       String
  description String       @db.Text
  type        InsightType
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())

  run         AnalysisRun  @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, sortOrder])
}

model RecommendationItem {
  id           String             @id @default(cuid())
  runId        String
  productId    String?
  kind         RecommendationKind
  title        String
  percentValue Int?
  bulletPoints String[]
  createdAt    DateTime           @default(now())

  run          AnalysisRun        @relation(fields: [runId], references: [id], onDelete: Cascade)
  product      Product?           @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([runId, kind])
}
